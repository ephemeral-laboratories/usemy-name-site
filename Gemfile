source 'https://rubygems.org'

gem 'jekyll'

group :jekyll_plugins do
    gem 'jekyll-seo-tag'
    gem 'jekyll-sitemap'
    gem 'jekyll-target-blank'
end

gem 'htmlbeautifier'

group :development do
    # To avoid polling for changes when running `jekyll server` on Windows
    gem 'wdm', '>= 0.1.0', platforms: [:mswin, :mingw]

    gem 'pry'
end
